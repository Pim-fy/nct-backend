<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    [MemberMapper.xml - 인증용 회원 조회/저장]
    - namespace : Java Mapper 인터페이스의 전체 경로와 일치
    - SQL id    : 인터페이스 메서드명과 일치
-->
<mapper namespace="nct.member.mapper.MemberMapper">

    
    <resultMap id="memberMap" type="nct.member.domain.Member">
        <id     column="USR_SN"                 property="usrSn"/>
        <result column="USR_LOGIN_ID"           property="usrLoginId"/>
        <result column="USR_PSWD_HASH"          property="usrPswdHash"/>
        <result column="USR_REFRESH_TOKEN_HASH" property="usrRefreshTokenHash"/>
        <result column="USR_NM"                 property="usrNm"/>
        <result column="USR_EML"                property="usrEml"/>
        <result column="USR_EML_CERT_YN"        property="usrEmlCertYn"/>
        <result column="USR_TELNO"              property="usrTelno"/>
        <result column="USR_ADDR"               property="usrAddr"/>
        <result column="USR_DADDR"              property="usrDaddr"/>
        <result column="USR_ZIP"                property="usrZip"/>
        <result column="USR_BANK_NM"            property="usrBankNm"/>
        <result column="USR_ACNT_NO"            property="usrAcntNo"/>
        <result column="USR_PRFL_FL_SN"         property="usrPrflFlSn"/>
        <result column="USR_STATUS_CD"          property="usrStatusCd"/>
        <result column="USR_ROLE_CD"            property="usrRoleCd"/>
        <result column="USR_ADULT_CERT_YN"      property="usrAdultCertYn"/>
        <result column="USR_ADULT_CERT_DT"      property="usrAdultCertDt"/>
        <result column="USR_USE_YN"             property="usrUseYn"/>
        <result column="USR_REG_DT"             property="usrRegDt"/>
        <result column="USR_UPDT_DT"            property="usrUpdtDt"/>
        <result column="USR_REG_ID"             property="usrRegId"/>
        <result column="USR_UPDT_ID"            property="usrUpdtId"/>
    </resultMap>

    <!-- @ai_generated: 통합검증 중 발견 - USR_USE_YN='Y' 필터가 있으면 탈퇴(USE_YN='N') 계정이
         "존재하지 않는 사용자"로 걸러져 F-AUTH-009의 WITHDRAWN_USER(410) 분기에 도달하지 못하고
         INVALID_CREDENTIALS(401)/USER_NOT_FOUND(404)로 뭉뚱그려졌다. 상태 판별은 USR_STATUS_CD로만
         하도록 이 필터를 제거한다(existsByLoginId/ByEmail/ByNickname도 원래 이 필터가 없어 회원가입
         재사용 방지 등 다른 목적과 충돌하지 않음을 확인했다). -->

    <!-- 이메일로 회원 조회 -->
    <select id="findMemberByEmail" parameterType="String" resultMap="memberMap">
        /* 이메일로 회원 조회 */
        SELECT
            USR_SN, USR_LOGIN_ID, USR_PSWD_HASH, USR_REFRESH_TOKEN_HASH, USR_NM, USR_EML,
            USR_EML_CERT_YN, USR_TELNO, USR_ADDR, USR_DADDR, USR_ZIP,
            USR_BANK_NM, USR_ACNT_NO, USR_PRFL_FL_SN, USR_STATUS_CD, USR_ROLE_CD,
            USR_ADULT_CERT_YN, USR_ADULT_CERT_DT, USR_USE_YN, USR_REG_DT, USR_UPDT_DT,
            USR_REG_ID, USR_UPDT_ID
        FROM   USERS
        WHERE  USR_EML = #{email}
    </select>

    <!-- @ai_generated: 로컬 로그인은 USR_LOGIN_ID로 조회하고 이메일은 JWT/인증용으로 유지한다. -->
    <select id="findMemberByLoginId" parameterType="String" resultMap="memberMap">
        SELECT
            USR_SN, USR_LOGIN_ID, USR_PSWD_HASH, USR_REFRESH_TOKEN_HASH, USR_NM, USR_EML,
            USR_EML_CERT_YN, USR_TELNO, USR_ADDR, USR_DADDR, USR_ZIP,
            USR_BANK_NM, USR_ACNT_NO, USR_PRFL_FL_SN, USR_STATUS_CD, USR_ROLE_CD,
            USR_ADULT_CERT_YN, USR_ADULT_CERT_DT, USR_USE_YN, USR_REG_DT, USR_UPDT_DT,
            USR_REG_ID, USR_UPDT_ID
        FROM USERS
        WHERE USR_LOGIN_ID = #{loginId}
    </select>

    <!-- @ai_generated: JWT subject(usrSn) 기반 조회 - 로그인 필터·재발급 검증에 사용 (가변 필드인 email 대신 불변 PK 사용) -->
    <select id="findMemberById" parameterType="Long" resultMap="memberMap">
        SELECT
            USR_SN, USR_LOGIN_ID, USR_PSWD_HASH, USR_REFRESH_TOKEN_HASH, USR_NM, USR_EML,
            USR_EML_CERT_YN, USR_TELNO, USR_ADDR, USR_DADDR, USR_ZIP,
            USR_BANK_NM, USR_ACNT_NO, USR_PRFL_FL_SN, USR_STATUS_CD, USR_ROLE_CD,
            USR_ADULT_CERT_YN, USR_ADULT_CERT_DT, USR_USE_YN, USR_REG_DT, USR_UPDT_DT,
            USR_REG_ID, USR_UPDT_ID
        FROM USERS
        WHERE USR_SN = #{usrSn}
    </select>

    <!-- @ai_generated: UNIQUE 제약 전 사전 확인은 UX용이며 최종 INSERT 제약도 별도로 처리한다. -->
    <select id="existsByLoginId" parameterType="String" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM USERS WHERE USR_LOGIN_ID = #{loginId})
    </select>

    <select id="existsByNickname" parameterType="String" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM USERS WHERE USR_NM = #{nickname})
    </select>

    <select id="existsByEmail" parameterType="String" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM USERS WHERE USR_EML = #{email})
    </select>

    <!-- @ai_generated: 인증 완료 가입만 USERS를 생성하고 이메일 인증 완료값을 함께 저장한다. -->
    <insert id="saveCertifiedMember" parameterType="nct.member.domain.Member"
            useGeneratedKeys="true" keyProperty="usrSn">
        /* 인증 완료 회원 가입 */
        INSERT INTO USERS (
            USR_LOGIN_ID, USR_PSWD_HASH, USR_NM, USR_EML, USR_EML_CERT_YN,
            USR_TELNO, USR_STATUS_CD, USR_ROLE_CD
        ) VALUES (
            #{usrLoginId}, #{usrPswdHash}, #{usrNm}, #{usrEml}, #{usrEmlCertYn},
            #{usrTelno}, #{usrStatusCd}, #{usrRoleCd}
        )
        <!-- 생략 컬럼 (USERS DDL 기준):
             · nullable(DEFAULT NULL): USR_REFRESH_TOKEN_HASH, USR_ADDR, USR_DADDR, USR_ZIP,
               USR_BANK_NM, USR_ACNT_NO, USR_PRFL_FL_SN, USR_ADULT_CERT_DT (가입 미입력 -> 생략)
             · DB DEFAULT 보유: USR_ADULT_CERT_YN('N'),
               USR_USE_YN('Y'), USR_REG_DT/USR_UPDT_DT(CURRENT_TIMESTAMP), USR_REG_ID/USR_UPDT_ID('SYSTEM')
             · USR_STATUS_CD 는 NOT NULL & DEFAULT 없음 -> 필수 지정 (어댑터에서 세팅) -->
    </insert>

    <!-- Refresh Token 저장/삭제 (로그인 시 저장, 로그아웃 시 null)
         · @ai_generated: 애플리케이션 계층(TokenHashUtil)에서 SHA-256 해시화한 값을 전달받아 저장한다 (원문 저장 금지)
         · USR_UPDT_DT 는 테이블 DDL 의 ON UPDATE CURRENT_TIMESTAMP 로 자동 갱신되므로 여기서 지정하지 않음 -->
    <update id="updateRefreshTokenById">
        /* Refresh Token 해시 갱신 */
        UPDATE USERS
        SET    USR_REFRESH_TOKEN_HASH = #{refreshTokenHash}
        WHERE  USR_SN = #{usrSn}
    </update>

</mapper>
