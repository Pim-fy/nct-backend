<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    [AuctionMapper.xml - 경매(AUCTION) 조회]
    - namespace : Java Mapper 인터페이스의 전체 경로와 일치
    - SQL id    : 인터페이스 메서드명과 일치
    - AUC_CUR_AMT, AUC_BID_UNIT_AMT 는 DDL 상 DECIMAL(15,0) 이지만
      자바 쪽은 Long 으로 받는다 (소수점이 없는 정수 금액이라 단순화).
-->
<mapper namespace="nct.auction.mapper.AuctionMapper">

    <resultMap id="auctionMap" type="nct.auction.domain.Auction">
        <id     column="AUC_SN"           property="aucSn"/>
        <result column="PRD_SN"           property="prdSn"/>
        <result column="AUC_STATUS_CD"    property="aucStatusCd"/>
        <result column="AUC_CUR_AMT"      property="aucCurAmt"/>
        <result column="AUC_BID_UNIT_AMT" property="aucBidUnitAmt"/>
        <result column="AUC_START_DT"     property="aucStartDt"/>
        <result column="AUC_END_DT"       property="aucEndDt"/>
        <result column="AUC_EXT_CNT"      property="aucExtCnt"/>
        <result column="AUC_REG_DT"       property="aucRegDt"/>
        <result column="AUC_UPDT_DT"      property="aucUpdtDt"/>
        <result column="AUC_REG_ID"       property="aucRegId"/>
        <result column="AUC_UPDT_ID"      property="aucUpdtId"/>
    </resultMap>

    <!-- 입찰 검증(F-AUC-013)용 경매 단건 조회 - 잠금 없음(읽기 전용 검증) -->
    <select id="findAuctionForBid" parameterType="Long" resultMap="auctionMap">
        /* 입찰 검증용 경매 단건 조회 */
        SELECT
            AUC_SN, PRD_SN, AUC_STATUS_CD, AUC_CUR_AMT, AUC_BID_UNIT_AMT,
            AUC_START_DT, AUC_END_DT, AUC_EXT_CNT,
            AUC_REG_DT, AUC_UPDT_DT, AUC_REG_ID, AUC_UPDT_ID
        FROM   AUCTION
        WHERE  AUC_SN = #{aucSn}
    </select>

    <!-- [F-AUC-014] 입찰 실행 전용 - FOR UPDATE 로 다른 트랜잭션의 동시 조회를 대기시킨다 -->
    <select id="findAuctionForUpdate" parameterType="Long" resultMap="auctionMap">
        /* 입찰 실행용 경매 단건 조회 (쓰기 잠금) */
        SELECT
            AUC_SN, PRD_SN, AUC_STATUS_CD, AUC_CUR_AMT, AUC_BID_UNIT_AMT,
            AUC_START_DT, AUC_END_DT, AUC_EXT_CNT,
            AUC_REG_DT, AUC_UPDT_DT, AUC_REG_ID, AUC_UPDT_ID
        FROM   AUCTION
        WHERE  AUC_SN = #{aucSn}
        FOR UPDATE
    </select>

    <!-- [F-AUC-014] 새 최고 입찰가 반영 -->
    <update id="updateCurrentAmount">
        /* 경매 현재금액 갱신 */
        UPDATE AUCTION
        SET    AUC_CUR_AMT = #{newAmt}
        WHERE  AUC_SN = #{aucSn}
    </update>

    <!-- [F-AUC-018] 즉시구매 성공 시 경매 상태 변경 (예: 진행중 -> 종료) -->
    <update id="updateStatus">
        /* 경매 상태 변경 */
        UPDATE AUCTION
        SET    AUC_STATUS_CD = #{statusCd}
        WHERE  AUC_SN = #{aucSn}
    </update>

</mapper>
