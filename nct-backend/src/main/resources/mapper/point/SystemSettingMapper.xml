<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="nct.point.mapper.SystemSettingMapper">

    <!-- 시스템 설정: 충전 한도 조회. SYSTEM_SETTING은 고정 컬럼 단일 row라(D-010) WHERE 없이 LIMIT 1만 건다 -->
    <select id="selectChargeLimits" resultType="nct.point.domain.SystemSetting">
        /* 시스템 설정: 충전 한도 조회 */
        SELECT
            SYS_SET_MIN_CHRG_AMT AS minChrgAmt,
            SYS_SET_MAX_CHRG_AMT AS maxChrgAmt
        FROM SYSTEM_SETTING
        LIMIT 1
    </select>

</mapper>
