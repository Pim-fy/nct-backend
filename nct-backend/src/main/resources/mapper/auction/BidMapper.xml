<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    [BidMapper.xml - 입찰(BID) 조회 전용] (F-AUC-022 내 입찰 내역 조회)
    - insertBid/findActiveBid/updateBidStatus(F-AUC-014/018 쓰기)는 AUCTION/BID 기술 소유권이
      담당자5로 이관되면서 삭제했다 (09_기능단위_7인_업무분장 v10, CHG-018).
    - 담당자5가 "내 입찰 조회" 계약을 제공하면 이 XML/매퍼 자체를 없애고 그 계약을 호출하도록
      바꿔야 한다 (BidMapper.java 상단 주석 참고).
-->
<mapper namespace="nct.auction.mapper.BidMapper">

    <resultMap id="myBidHistoryMap" type="nct.auction.dto.MyBidHistoryItem">
        <id     column="BID_SN"        property="bidSn"/>
        <result column="AUC_SN"        property="aucSn"/>
        <result column="BID_AMT"       property="bidAmt"/>
        <result column="BID_STATUS_CD" property="bidStatusCd"/>
        <result column="AUC_STATUS_CD" property="auctionStatusCd"/>
        <result column="BID_REG_DT"    property="bidRegDt"/>
    </resultMap>

    <!-- [F-AUC-022] 내 입찰 내역 - 최신 입찰이 위로 오도록 정렬 -->
    <select id="findMyBidHistory" parameterType="Long" resultMap="myBidHistoryMap">
        /* 내 입찰 내역 조회 (BID + AUCTION 조인) */
        SELECT
            b.BID_SN, b.AUC_SN, b.BID_AMT, b.BID_STATUS_CD, b.BID_REG_DT,
            a.AUC_STATUS_CD
        FROM   BID b
        JOIN   AUCTION a ON a.AUC_SN = b.AUC_SN
        WHERE  b.USR_SN = #{usrSn}
        ORDER  BY b.BID_REG_DT DESC
    </select>

</mapper>
